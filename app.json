{
  "expo": {
    "name": "English Quest",
    "slug": "english-quest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "englishquest",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.englishquest.app"
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.englishquest.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#8b5cf6"
        }
      ],
      "expo-sharing",
      "expo-dev-client",
      "expo-focus-mode",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
