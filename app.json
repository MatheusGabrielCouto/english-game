{
  "expo": {
    "name": "English Quest",
    "slug": "english-quest",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "englishquest",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.englishquest.app"
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#06060b"
      },
      "package": "com.englishquest.app",
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "headers": {
            "Cross-Origin-Embedder-Policy": "credentialless",
            "Cross-Origin-Opener-Policy": "same-origin"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06060b",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#06060b",
            "image": "./assets/splash-icon.png"
          },
          "ios": {
            "backgroundColor": "#06060b",
            "image": "./assets/splash-icon.png",
            "imageWidth": 220
          },
          "android": {
            "backgroundColor": "#06060b",
            "image": "./assets/splash-icon.png",
            "imageWidth": 220
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "color": "#8b5cf6"
        }
      ],
      "expo-sharing",
      "expo-dev-client",
      "expo-focus-mode",
      [
        "expo-audio",
        {
          "microphonePermission": "O English Quest precisa do microfone para gravar notas de voz no seu diário de inglês."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "O English Quest precisa do microfone para gravar e transcrever notas de voz.",
          "speechRecognitionPermission": "O English Quest usa reconhecimento de fala para transcrever suas gravações em inglês."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O English Quest precisa acessar suas fotos para anexar imagens às notas do diário.",
          "cameraPermission": "O English Quest precisa da câmera para tirar fotos nas notas do diário."
        }
      ],
      [
        "@react-native-community/datetimepicker",
        {
          "android": {
            "timePicker": {
              "background": {
                "light": "#0f0f18",
                "dark": "#0f0f18"
              },
              "headerBackground": {
                "light": "#161622",
                "dark": "#161622"
              },
              "numbersBackgroundColor": {
                "light": "#0f0f18",
                "dark": "#0f0f18"
              },
              "numbersTextColor": {
                "light": "#fafafa",
                "dark": "#fafafa"
              },
              "numbersSelectorColor": {
                "light": "#8b5cf6",
                "dark": "#8b5cf6"
              }
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
