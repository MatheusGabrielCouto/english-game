<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.focusmode" >

    <uses-sdk android:minSdkVersion="24" />

    <application>
        <service
            android:name="expo.modules.focusmode.FocusAccessibilityService"
            android:exported="true"
            android:label="@string/focus_accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE" >
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/focus_accessibility_service_config" />
        </service>
    </application>

</manifest>