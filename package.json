    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "android:apk:release": "cd android && ./gradlew assembleRelease",
    "android:apk:debug": "cd android && ./gradlew assembleDebug",
    "android:build:preview": "eas build --platform android --profile preview --non-interactive",
    "ios": "expo run:ios",
    "web": "expo start --web",
